# =============================================================
# Public — intégré au bundle navigateur (lisible côté client)
# Aucune valeur secrète ne doit porter le préfixe NEXT_PUBLIC_
# =============================================================
NEXT_PUBLIC_ESIGNET_CLIENT_ID=<client-id>
NEXT_PUBLIC_ESIGNET_AUTHORIZE_URL=https://esignet.benin.mosip.net/authorize
NEXT_PUBLIC_ESIGNET_PLUGIN_URL=https://esignet.benin.mosip.net/plugins/sign-in-button-plugin.js
NEXT_PUBLIC_ESIGNET_SCOPE=openid profile email phone
NEXT_PUBLIC_ESIGNET_REDIRECT_URI=
NEXT_PUBLIC_ESIGNET_PROMPT=consent
NEXT_PUBLIC_ESIGNET_DISPLAY=page
# À n'activer qu'APRÈS confirmation de l'onboarding des claims :
NEXT_PUBLIC_ESIGNET_CLAIMS=

# =============================================================
# Serveur — ne JAMAIS préfixer par NEXT_PUBLIC_, ne jamais commiter
# =============================================================
ESIGNET_CLIENT_ID=<même-client-id>
# Clé PKCS#8. Les sauts de ligne sont encodés en \n (voir keys/env-snippet.txt) :
ESIGNET_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
ESIGNET_KEY_ID=<kid-de-la-jwk-publiee>
ESIGNET_SESSION_SECRET=<secret-aleatoire-fort-32-octets-min>
ESIGNET_ISSUER=https://esignet.benin.mosip.net
ESIGNET_TOKEN_URL=https://esignet.benin.mosip.net/v1/esignet/oauth/v2/token
ESIGNET_USERINFO_URL=https://esignet.benin.mosip.net/v1/esignet/oidc/userinfo
ESIGNET_JWKS_URL=https://esignet.benin.mosip.net/.well-known/jwks.json
# false par défaut ; exception de compatibilité temporaire uniquement.
ESIGNET_ALLOW_UNVERIFIED_USERINFO=false
